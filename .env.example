# For local dev with docker compose, these are overridden by docker-compose.yml.
# This file documents what the API needs if you run it outside Docker.

PORT=3000
MONGODB_URI=mongodb://localhost:27017/comandas?replicaSet=rs0&directConnection=true
SECRET_KEY_TOKEN=replace_with_a_random_32+_char_string
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BCRYPT_ROUNDS=12
STORAGE_DRIVER=local
